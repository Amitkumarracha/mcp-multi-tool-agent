# OpenAI API Key (required for LangChain agent)
OPENAI_API_KEY=your_openai_api_key_here

# Tavily API Key (required for web search)
# Get your free API key at: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# News API Key (required for news search)
# Get your free API key at: https://newsapi.org/
NEWS_API_KEY=your_newsapi_key_here

# Currency API Key (optional - has free tier fallback)
# Get your free API key at: https://currencyapi.com/
CURRENCY_API_KEY=your_currencyapi_key_here
